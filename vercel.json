{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com; font-src 'self' https://cdn.fontshare.com; img-src 'self' data: https://ui-avatars.com https://pbs.twimg.com https://www.google.com; connect-src 'self' https://vitals.vercel-analytics.com; frame-ancestors 'none'; form-action 'self' https://buttondown.com; base-uri 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|ico|avif)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(sitemap\\.xml|sitemap-index\\.xml|news-sitemap\\.xml|robots\\.txt|llms\\.txt|rss\\.xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=600"
        }
      ]
    },
    {
      "source": "/(install\\.sh|install-cli\\.sh|install\\.ps1)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/publications/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "openclaw.ai"
        }
      ],
      "destination": "https://docs.openclaw.ai/",
      "statusCode": 308
    },
    {
      "source": "/docs/",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "openclaw.ai"
        }
      ],
      "destination": "https://docs.openclaw.ai/",
      "statusCode": 308
    },
    {
      "source": "/docs/:path*",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "openclaw.ai"
        }
      ],
      "destination": "https://docs.openclaw.ai/:path*",
      "statusCode": 308
    },
    {
      "source": "/docs/:path*/",
