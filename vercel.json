{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://api.fontshare.com; font-src 'self' https://cdn.fontshare.com; img-src 'self' data: https://ui-avatars.com https://pbs.twimg.com; connect-src 'self' https://vitals.vercel-analytics.com; frame-ancestors 'none'; form-action 'self' https://buttondown.com; base-uri 'self'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "^/publications/?$",
      "status": 308,
      "headers": { "Location": "/publications/clawhub-security-signals.pdf" }
    },
    {
      "src": "^/publications/clawhub-security-signals/?$",
      "status": 308,
      "headers": { "Location": "/publications/clawhub-security-signals.pdf" }
    },
    {
      "src": "^/discord/?$",
      "has": [{ "type": "host", "value": "openclaw.ai" }],
      "status": 302,
      "headers": { "Location": "https://discord.gg/clawd" }
    },
    {
      "src": "^/blog/performance-size-supply-chain-sweep/?$",
      "status": 308,
      "headers": { "Location": "/blog/lighter-core-sharper-claws/" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "blog.openclaw.ai" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/blog/$1" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "trust.openclaw.ai" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/blog#security" }
    },
    {
      "src": "^/trust(/.*)?$",
      "status": 308,
      "headers": { "Location": "/blog#security" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "clawd.bot" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/$1" }
    },
    {
      "src": "^/(.*)$",
      "has": [{ "type": "host", "value": "www.clawd.bot" }],
      "status": 308,
      "headers": { "Location": "https://openclaw.ai/$1" }
    }
  ]
}
