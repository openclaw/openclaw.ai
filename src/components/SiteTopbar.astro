---
interface NavItem {
  href: string;
  label: string;
  external?: boolean;
}

interface Props {
  active?: 'home' | 'blog' | 'docs' | 'ecosystem';
}

const { active = 'home' } = Astro.props;
const items: NavItem[] = [
  { href: '/', label: 'Product' },
  { href: '/ecosystem', label: 'Ecosystem' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.openclaw.ai/', label: 'Docs', external: true },
  { href: 'https://github.com/openclaw/openclaw', label: 'GitHub', external: true },
];

function isActive(item: NavItem) {
  if (active === 'home') return item.href === '/';
  if (active === 'blog') return item.href === '/blog';
  if (active === 'docs') return item.label === 'Docs';
  if (active === 'ecosystem') return item.href === '/ecosystem';
  return false;
}
---

<header class="site-topbar">
  <a href="/" class="site-brand" aria-label="OpenClaw home">
    <img src="/favicon.svg" alt="" />
    <span>OpenClaw</span>
  </a>
  <nav class="site-nav" aria-label="Main">
    {items.map((item) => (
      <a
        href={item.href}
        class:list={['site-nav-link', { active: isActive(item) }]}
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener' : undefined}
        aria-current={isActive(item) && !item.external ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-topbar {
    position: sticky;
    top: 0;
    z-index: 90;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 62px;
    padding: 0 82px 0 32px;
    border-bottom: 1px solid var(--border-subtle);
    background: color-mix(in srgb, var(--bg-deep) 88%, transparent);
    backdrop-filter: blur(18px);
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0;
  }

  .site-brand img {
    width: 24px;
    height: 24px;
    filter: drop-shadow(0 0 12px var(--logo-glow));
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    overflow-x: auto;
    white-space: nowrap;
  }

  .site-nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid transparent;
    border-radius: 8px;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.16s ease, background 0.16s ease, border-color 0.16s ease;
  }

  .site-nav-link:hover,
  .site-nav-link.active {
    color: var(--text-primary);
    background: var(--surface-card);
    border-color: var(--border-subtle);
  }

  .site-nav-link.active {
    color: var(--coral-bright);
  }

  @media (max-width: 720px) {
    .site-topbar {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
      padding: 12px 58px 12px 16px;
    }

    .site-nav {
      width: 100%;
      padding-bottom: 2px;
    }

    .site-nav-link {
      min-height: 32px;
      padding: 0 10px;
      font-size: 0.84rem;
    }
  }
</style>
