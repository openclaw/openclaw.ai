---
import { FileText, Megaphone } from '@lucide/astro';
import { siDiscord, siGithub } from 'simple-icons';

type SimpleIcon = {
  kind: 'simple';
  path: string;
};

type ComponentIcon = {
  kind: 'component';
  component: typeof FileText;
};

type NavIcon = SimpleIcon | ComponentIcon;

interface NavItem {
  href: string;
  label: string;
  external?: boolean;
  icon?: NavIcon;
}

interface Props {
  active?: 'home' | 'blog' | 'docs' | 'ecosystem' | 'integrations';
}

const { active = 'home' } = Astro.props;
const items: NavItem[] = [
  { href: '/', label: 'Product' },
  { href: '/ecosystem', label: 'Ecosystem' },
  { href: '/integrations', label: 'Integrations' },
  { href: '/blog', label: 'Blog', icon: { kind: 'component', component: Megaphone } },
  {
    href: 'https://docs.openclaw.ai/',
    label: 'Docs',
    external: true,
    icon: { kind: 'component', component: FileText },
  },
  {
    href: 'https://discord.com/invite/clawd',
    label: 'Discord',
    external: true,
    icon: { kind: 'simple', path: siDiscord.path },
  },
  {
    href: 'https://github.com/openclaw/openclaw',
    label: 'GitHub',
    external: true,
    icon: { kind: 'simple', path: siGithub.path },
  },
];

function isActive(item: NavItem) {
  if (active === 'home') return item.href === '/';
  if (active === 'blog') return item.href === '/blog';
  if (active === 'docs') return item.label === 'Docs';
  if (active === 'ecosystem') return item.href === '/ecosystem';
  if (active === 'integrations') return item.href === '/integrations';
  return false;
}
---

<header class="site-topbar">
  <a href="/" class="site-brand" aria-label="OpenClaw home">
    <img src="/favicon.svg" alt="" />
    <span>OpenClaw</span>
  </a>
  <nav class="site-nav site-nav-desktop" aria-label="Main">
    {items.map((item) => (
      <a
        href={item.href}
        class:list={['site-nav-link', { active: isActive(item) }]}
        target={item.external ? '_blank' : undefined}
        rel={item.external ? 'noopener' : undefined}
        aria-current={isActive(item) && !item.external ? 'page' : undefined}
      >
        {item.icon?.kind === 'simple' && (
          <svg class="site-nav-icon site-nav-icon-simple" viewBox="0 0 24 24" aria-hidden="true">
            <path d={item.icon.path} />
          </svg>
        )}
        {item.icon?.kind === 'component' && (
          <item.icon.component class="site-nav-icon site-nav-icon-lucide" size={14} aria-hidden="true" />
        )}
        {item.label}
      </a>
    ))}
  </nav>
  <details class="site-menu">
    <summary class="site-menu-toggle" aria-label="Toggle main navigation">
      <span class="site-burger" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </summary>
    <nav class="site-menu-panel" aria-label="Main">
      {items.map((item) => (
        <a
          href={item.href}
          class:list={['site-nav-link', { active: isActive(item) }]}
          target={item.external ? '_blank' : undefined}
          rel={item.external ? 'noopener' : undefined}
          aria-current={isActive(item) && !item.external ? 'page' : undefined}
        >
          {item.icon?.kind === 'simple' && (
            <svg class="site-nav-icon site-nav-icon-simple" viewBox="0 0 24 24" aria-hidden="true">
              <path d={item.icon.path} />
            </svg>
          )}
          {item.icon?.kind === 'component' && (
            <item.icon.component class="site-nav-icon site-nav-icon-lucide" size={14} aria-hidden="true" />
          )}
          {item.label}
        </a>
      ))}
    </nav>
  </details>
</header>

<style>
  .site-topbar {
    position: sticky;
    top: 0;
    z-index: 90;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 54px;
    padding: 0 76px 0 32px;
    border-bottom: 1px solid var(--border-subtle);
    background: color-mix(in srgb, var(--bg-deep) 72%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text-primary);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .site-brand img {
    width: 22px;
    height: 22px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 26px;
    overflow-x: auto;
    white-space: nowrap;
  }

  .site-menu {
    display: none;
  }

  .site-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 34px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .site-nav-icon {
    width: 14px;
    height: 14px;
    flex: 0 0 auto;
    stroke-width: 2.1;
  }

  .site-nav-icon-simple {
    fill: currentColor;
    stroke: none;
  }

  .site-nav-icon-lucide {
    fill: none;
  }

  .site-nav-link:hover {
    color: var(--text-primary);
  }

  .site-nav-link.active {
    color: var(--coral-bright);
  }

  @media (max-width: 720px) {
    .site-topbar {
      align-items: center;
      flex-direction: row;
      gap: 16px;
      min-height: 52px;
      padding: 0 58px 0 20px;
    }

    .site-nav.site-nav-desktop {
      display: none;
    }

    .site-menu {
      position: relative;
      display: block;
      margin-left: auto;
    }

    .site-menu-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 8px 4px;
      border: none;
      background: none;
      color: var(--text-muted);
      cursor: pointer;
      list-style: none;
      transition: color 150ms ease;
    }

    .site-menu-toggle::-webkit-details-marker {
      display: none;
    }

    .site-menu-toggle:hover,
    .site-menu[open] .site-menu-toggle {
      color: var(--text-primary);
    }

    .site-menu-toggle:focus-visible {
      outline: 2px solid var(--coral-bright);
      outline-offset: 2px;
    }

    /* Burger: three lines morphing into an X, per the Foundation site */
    .site-burger {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .site-burger span {
      display: block;
      width: 18px;
      height: 1.6px;
      border-radius: 1px;
      background: currentColor;
      transition: transform 250ms ease, opacity 200ms ease;
    }

    .site-menu[open] .site-burger span:nth-child(1) {
      transform: translateY(5.6px) rotate(45deg);
    }

    .site-menu[open] .site-burger span:nth-child(2) {
      opacity: 0;
    }

    .site-menu[open] .site-burger span:nth-child(3) {
      transform: translateY(-5.6px) rotate(-45deg);
    }

    .site-menu-panel {
      position: fixed;
      top: 52px;
      right: 12px;
      left: 12px;
      z-index: 92;
      display: grid;
      gap: 4px;
      padding: 8px;
      border: 1px solid var(--border-subtle);
      border-radius: 0;
      background: color-mix(in srgb, var(--bg-deep) 96%, transparent);
      box-shadow: none;
      backdrop-filter: blur(18px);
    }

    .site-menu-panel .site-nav-link {
      width: 100%;
      min-height: 42px;
      justify-content: flex-start;
      padding: 0 12px;
      font-size: 0.9rem;
    }
  }
</style>
