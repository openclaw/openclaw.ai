---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import SiteTopbar from '../../components/SiteTopbar.astro';
import { render } from 'astro:content';
import { getPublishedBlogPosts } from '../../lib/blog';
import { resolveBlogSocialImage } from '../../lib/blog-social-image';
import { authorSlug, getSortedAuthorLinkMeta, resolveAuthorProfile, type BlogAuthor } from '../../lib/authors';
import { getCachedXAvatarSrc, getInitialsAvatarSrc } from '../../lib/avatars';
import { sanitizeUrl } from '../../lib/sanitize-url';
import { absoluteUrl, blogPostPath } from '../../lib/seo';
import { siX } from 'simple-icons';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getPublishedBlogPosts();
const { Content, headings } = await render(post);

const rawAuthors: BlogAuthor[] = post.data.authors
  ?? (post.data.author
    ? [{
      name: post.data.author,
      handle: post.data.authorHandle,
      url: post.data.authorUrl,
      avatar: post.data.authorAvatar,
    }]
    : []);
const authors = rawAuthors.map(resolveAuthorProfile);

function getAuthorAvatar(author: BlogAuthor): string {
  return author.avatar ?? (author.handle ? getCachedXAvatarSrc(author.handle, author.name, 88) : '/openclaw-logo-text-dark.png');
}

const siIcon = (icon: { path: string }) => icon.path;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function estimateReadTime(content: string): string {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 220))} min read`;
}

const toc = headings
  .filter((heading) => heading.depth === 2 || heading.depth === 3)
  .map((heading) => ({
    level: heading.depth,
    title: heading.text,
    id: heading.slug,
  }))
  .slice(0, 16);

const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => ({
    post: candidate,
    score: candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf())
  .slice(0, 3)
  .map((item) => item.post);

const canonicalPostUrl = absoluteUrl(blogPostPath(post));
const ogImage = resolveBlogSocialImage(post.id, post.data.ogImage);
const articleImageUrl = absoluteUrl(ogImage.src);

const descriptionHtml = post.data.descriptionHtml ?? post.data.description;
const structuredAuthors = authors.map((author) => {
  const sameAs = getSortedAuthorLinkMeta(author)
    .map((link) => link.url)
    .filter((url) => sanitizeUrl(url) !== '#');
  return {
    '@type': 'Person',
    name: author.name,
    url: absoluteUrl(`/blog/authors/${authorSlug(author.name)}`),
    ...(sameAs.length ? { sameAs } : {}),
  };
});
const articleStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: canonicalPostUrl,
  mainEntityOfPage: canonicalPostUrl,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  image: [articleImageUrl],
  author: structuredAuthors.length > 0 ? structuredAuthors : [{ '@type': 'Organization', name: 'OpenClaw' }],
  publisher: {
    '@type': 'Organization',
    name: 'OpenClaw',
    logo: {
      '@type': 'ImageObject',
      url: absoluteUrl('/logo.png'),
    },
  },
};
---

<Layout
  title={`${post.data.title} - OpenClaw Blog`}
  description={post.data.description}
  canonicalUrl={canonicalPostUrl}
  ogImage={ogImage.src}
  ogImageWidth={ogImage.width}
  ogImageHeight={ogImage.height}
  ogImageType={ogImage.type}
  ogType="article"
  structuredData={articleStructuredData}
>
  <SiteTopbar active="blog" />
  <main class="reader-shell">
    <article class="article">
      <header class="article-header">
        <a class="back-link" href="/blog"><span aria-hidden="true">←</span> All posts</a>
        <h1>{post.data.title}</h1>
        <p class="dek" set:html={descriptionHtml} />

        <div class="byline">
          <div class="byline-avatars">
            {authors.map((author) => (
              <a href={`/blog/authors/${authorSlug(author.name)}`} title={[author.name, author.title, author.org].filter(Boolean).join(' — ')}>
                <img
                  src={getAuthorAvatar(author)}
                  alt={author.name}
                  loading="lazy"
                  onerror={`this.src='${getInitialsAvatarSrc(author.name, 88)}'`}
                />
              </a>
            ))}
          </div>
          <div class="byline-names">
            {authors.map((author, index) => (
              <>
                {index > 0 && <span class="byline-sep">·</span>}
                <a
                  href={`/blog/authors/${authorSlug(author.name)}`}
                  title={[author.title, author.org].filter(Boolean).join(', ')}
                >{author.name}</a>
              </>
            ))}
          </div>
          <span class="byline-meta">{formatDate(post.data.date)} · {estimateReadTime(post.body || '')}</span>
        </div>

        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="article-header-image" />
        )}
      </header>

      <div class="article-content" data-article-content>
        <Content />
      </div>

      <footer class="article-footer">
        <div class="footer-tags" aria-label="Filed under">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <section class="share-section">
          <span>Share this post</span>
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(canonicalPostUrl)}&via=openclaw`}
            class="share-link share-link-icon"
            target="_blank"
            rel="noopener"
            aria-label="Share on X"
            title="Share on X"
          >
            <Icon icon={siIcon(siX)} size={14} />
          </a>
          <a class="share-link" href={`https://news.ycombinator.com/submitlink?u=${encodeURIComponent(canonicalPostUrl)}&t=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener">
            Hacker News
          </a>
        </section>

        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <h2>Keep reading</h2>
            <div>
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.id}`}>
                  <span>{formatDate(related.data.date)}</span>
                  <strong>{related.data.title}</strong>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="cta-box">
          <div>
            <h2>Build from the docs</h2>
            <p>Install, configure, and harden OpenClaw with the same reading layout.</p>
          </div>
          <a class="oc-action oc-action-primary" href="https://docs.openclaw.ai/start/getting-started" target="_blank" rel="noopener">Open docs</a>
        </section>
      </footer>
    </article>

    <aside class="reader-toc" aria-label="On this page">
      {toc.length > 0 && (
        <>
          <h2>On this page</h2>
          {toc.map((item) => (
            <a class:list={[`toc-l${item.level}`]} href={`#${item.id}`}>{item.title}</a>
          ))}
        </>
      )}
      <div class="toc-related">
        <h2>Related docs</h2>
        <a href="https://docs.openclaw.ai/gateway/security" target="_blank" rel="noopener">Security</a>
        <a href="https://docs.openclaw.ai/plugins" target="_blank" rel="noopener">Plugins</a>
        <a href="https://docs.openclaw.ai/providers/openai" target="_blank" rel="noopener">OpenAI</a>
      </div>
    </aside>
  </main>

<script>
  const articleContent = document.querySelector('[data-article-content]');
  const expandedImageFrames = new Set<HTMLElement>();

  function getImageFrame(image: HTMLImageElement): HTMLElement {
    const figure = image.closest('figure:not(.chart-card)');
    return figure instanceof HTMLElement ? figure : image;
  }

  function collapseImageFrame(frame: HTMLElement) {
    frame.classList.remove('is-expanded');
    expandedImageFrames.delete(frame);

    const image = frame instanceof HTMLImageElement ? frame : frame.querySelector('img[data-expandable-image]');
    if (image instanceof HTMLImageElement) {
      image.setAttribute('aria-expanded', 'false');
      image.setAttribute('aria-label', 'Expand image');
    }
  }

  if (articleContent) {
    const expandableImages = articleContent.querySelectorAll<HTMLImageElement>('img');

    expandableImages.forEach((image) => {
      if (image.closest('.chart-card, a, button')) return;

      const frame = getImageFrame(image);
      frame.dataset.expandableFrame = '';
      image.dataset.expandableImage = '';
      image.tabIndex = 0;
      image.role = 'button';
      image.setAttribute('aria-expanded', 'false');
      image.setAttribute('aria-label', 'Expand image');

      function toggleImage() {
        const nextExpanded = !frame.classList.contains('is-expanded');

        expandedImageFrames.forEach((expandedFrame) => {
          if (expandedFrame !== frame) collapseImageFrame(expandedFrame);
        });

        frame.classList.toggle('is-expanded', nextExpanded);
        image.setAttribute('aria-expanded', String(nextExpanded));
        image.setAttribute('aria-label', nextExpanded ? 'Collapse image' : 'Expand image');

        if (nextExpanded) {
          expandedImageFrames.add(frame);
        } else {
          expandedImageFrames.delete(frame);
        }
      }

      image.addEventListener('click', toggleImage);
      image.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        toggleImage();
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      expandedImageFrames.forEach(collapseImageFrame);
    });
  }

  // Scroll spy: highlight the "On this page" entry for the section in view.
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.reader-toc a'));
  if (tocLinks.length > 0) {
    const headings = tocLinks
      .map((link) => document.getElementById(decodeURIComponent(link.hash.slice(1))))
      .filter((el): el is HTMLElement => el !== null);
    let activeId: string | null = null;
    let spyTick = false;

    const updateActiveHeading = () => {
      spyTick = false;
      let currentId = headings[0]?.id ?? null;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= 130) {
          currentId = heading.id;
        } else {
          break;
        }
      }
      if (currentId === activeId) return;
      activeId = currentId;
      for (const link of tocLinks) {
        link.classList.toggle('active', decodeURIComponent(link.hash.slice(1)) === currentId);
      }
    };

    const onScrollSpy = () => {
      if (spyTick) return;
      spyTick = true;
      requestAnimationFrame(updateActiveHeading);
    };

    window.addEventListener('scroll', onScrollSpy, { passive: true });
    window.addEventListener('resize', onScrollSpy, { passive: true });
    updateActiveHeading();
  }
</script>

</Layout>

<style>
  .reader-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 720px) 220px;
    justify-content: center;
    gap: 72px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 54px var(--oc-space-6) 96px;
  }

  .reader-toc {
    position: sticky;
    top: 92px;
    align-self: start;
    max-height: calc(100vh - 120px);
    overflow: auto;
  }

  .back-link,
  .reader-toc a {
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover,
  .reader-toc a:hover {
    color: var(--oc-text-primary);
  }

  .reader-toc a.active {
    color: var(--oc-accent-primary);
  }

  .back-link {
    display: inline-block;
    margin-bottom: 26px;
    font-size: 0.76rem;
  }

  .toc-related {
    margin-top: 30px;
    padding-top: var(--oc-space-5);
    border-top: 1px solid var(--oc-border-subtle);
  }

  .toc-related:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .article-kicker,
  .reader-toc h2 {
    margin: 0 0 var(--oc-space-3);
    color: var(--oc-accent-primary);
    font-family: var(--oc-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }


  .article {
    min-width: 0;
  }

  .article-header {
    margin-bottom: 42px;
  }

  .article h1 {
    margin: 0;
    color: var(--oc-text-primary);
    font-family: var(--oc-font-display);
    font-size: clamp(1.9rem, 4.2vw, 2.9rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .dek {
    margin-top: 18px;
    max-width: 700px;
    color: var(--oc-text-secondary);
    font-size: 1.18rem;
    line-height: 1.65;
  }

  .dek :global(a) {
    color: var(--oc-accent-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .dek :global(a:hover) {
    color: var(--oc-accent-secondary);
  }

  .article-header-image {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 1;
    object-fit: cover;
    object-position: center 62%;
    margin-top: 30px;
    background: #0a0a0c;
  }

  /* Byline: one ruled strip — avatars, names, date, read time */
  .byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: var(--oc-space-5);
    padding: 14px 0;
    border-top: 1px solid var(--oc-border-subtle);
    border-bottom: 1px solid var(--oc-border-subtle);
  }

  .byline-avatars {
    display: flex;
    align-items: center;
  }

  .byline-avatars a {
    display: inline-flex;
    border-radius: 50%;
  }

  .byline-avatars a + a {
    margin-left: -8px;
  }

  .byline-avatars img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--oc-bg-page);
    background: var(--oc-bg-elevated);
    filter: grayscale(1);
    transition: filter 0.25s ease;
  }

  .byline:hover .byline-avatars img {
    filter: grayscale(0);
  }

  .byline-names {
    color: var(--oc-text-primary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .byline-names a {
    color: inherit;
    text-decoration: none;
  }

  .byline-names a:hover {
    color: var(--oc-accent-primary);
  }

  .byline-sep {
    margin: 0 6px;
    color: var(--oc-text-muted);
  }

  .byline-meta {
    margin-left: auto;
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.74rem;
  }

  .article-content {
    --release-card-bg: color-mix(in srgb, var(--oc-surface-card-strong) 84%, var(--oc-bg-elevated));
    --release-card-border: color-mix(in srgb, var(--oc-text-muted) 30%, var(--oc-border-subtle));
    --release-card-highlight: color-mix(in srgb, var(--oc-text-primary) 5%, transparent);
    --release-data-ink: color-mix(in srgb, var(--oc-accent-secondary) 58%, var(--oc-text-primary));
    --release-risk-ink: color-mix(in srgb, var(--oc-accent-primary) 46%, var(--oc-text-primary));
    --release-track: color-mix(in srgb, var(--oc-surface-card-strong) 72%, var(--oc-bg-page));
    --article-inline-code-bg: color-mix(in srgb, var(--oc-bg-page) 60%, var(--oc-bg-surface));
    --article-code-bg: #0c0c0f;
    --article-code-border: rgba(154, 154, 162, 0.2);
    --article-code-text: #cfcfd6;
    color: var(--oc-text-secondary);
    font-size: 1.02rem;
    line-height: 1.78;
  }

  :global(html[data-theme='light']) .article-content {
    --release-card-bg: color-mix(in srgb, var(--oc-surface-card-strong) 90%, var(--oc-bg-elevated));
    --release-card-border: color-mix(in srgb, var(--oc-text-muted) 34%, var(--oc-border-subtle));
    --release-card-highlight: color-mix(in srgb, var(--oc-text-primary) 4%, transparent);
    --release-data-ink: color-mix(in srgb, var(--oc-accent-secondary) 68%, var(--oc-text-primary));
    --release-risk-ink: color-mix(in srgb, var(--oc-accent-primary) 56%, var(--oc-text-primary));
    --release-track: color-mix(in srgb, var(--oc-bg-elevated) 78%, white);
    --article-inline-code-bg: var(--oc-bg-elevated);
    --article-code-bg: var(--oc-bg-elevated);
    --article-code-border: var(--oc-border-subtle);
    --article-code-text: var(--oc-text-primary);
  }

  .article-content :global(p:first-child) {
    color: var(--oc-text-primary);
    font-size: 1.18rem;
    line-height: 1.72;
  }

  .article-content :global(p),
  .article-content :global(ul),
  .article-content :global(ol),
  .article-content :global(blockquote),
  .article-content :global(pre),
  .article-content :global(figure) {
    margin: 0 0 1.25em;
  }

  .article-content :global(h2) {
    margin: 2.4em 0 0.7em;
    padding-top: 1.1em;
    border-top: 1px solid var(--oc-border-subtle);
    color: var(--oc-text-primary);
    font-family: var(--oc-font-display);
    font-size: 1.45rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .article-content :global(h3) {
    margin: 1.9em 0 0.55em;
    color: var(--oc-text-primary);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.35rem;
  }

  .article-content :global(ol) {
    margin: 0 0 28px;
    padding-left: 0;
    list-style-position: inside;
  }

  .article-content :global(li) {
    margin: 0.25em 0;
  }

  .article-content :global(ol li) {
    margin-bottom: var(--oc-space-3);
    padding-left: 0;
  }

  .article-content :global(li::marker) {
    color: var(--oc-accent-primary);
  }

  .article-content :global(table) {
    width: 100%;
    max-width: 100%;
    margin: 28px 0 30px;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    table-layout: fixed;
    box-sizing: border-box;
    border: 1px solid var(--oc-border-subtle);
    border-radius: var(--oc-radius-surface);
    background: var(--oc-surface-card-strong);
    box-shadow: none;
    font-variant-numeric: tabular-nums;
  }

  .article-content :global(th),
  .article-content :global(td) {
    padding: 14px var(--oc-space-4);
    border-bottom: 1px solid var(--oc-border-subtle);
    vertical-align: middle;
  }

  .article-content :global(th) {
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.4;
    text-align: left;
    background: rgba(255, 255, 255, 0.03);
  }

  .article-content :global(td) {
    color: var(--oc-text-secondary);
    font-size: 0.98rem;
    line-height: 1.45;
  }

  .article-content :global(tbody tr:nth-child(odd) td) {
    background: rgba(255, 255, 255, 0.018);
  }

  .article-content :global(tbody tr:last-child td) {
    border-bottom: 0;
  }

  .article-content :global(th:first-child),
  .article-content :global(td:first-child) {
    width: 48%;
  }

  .article-content :global(th:nth-child(2)),
  .article-content :global(td:nth-child(2)) {
    width: 22%;
  }

  .article-content :global(th:nth-child(3)),
  .article-content :global(td:nth-child(3)) {
    width: 30%;
  }

  .article-content :global(th:nth-child(n + 2)),
  .article-content :global(td:nth-child(n + 2)) {
    text-align: right;
  }

  .article-content :global(td:nth-child(n + 2)) {
    white-space: nowrap;
  }

  .article-content :global(strong) {
    color: var(--oc-text-primary);
    font-weight: 800;
  }

  .article-content :global(a) {
    color: var(--oc-accent-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(a:hover) {
    color: color-mix(in srgb, var(--oc-accent-primary) 70%, var(--oc-text-primary));
  }

  .article-content :global(code) {
    padding: 0.08em 0.36em;
    border: 1px solid var(--oc-border-subtle);
    border-radius: var(--oc-radius-inset);
    background: var(--article-inline-code-bg);
    color: var(--oc-accent-secondary);
    font-family: var(--oc-font-mono);
    font-size: 0.88em;
  }

  .article-content :global(pre) {
    overflow: auto;
    padding: 18px 20px;
    border: 1px solid var(--article-code-border);
    background: var(--article-code-bg);
    color: var(--article-code-text);
    font-size: 0.86rem;
    line-height: 1.65;
  }

  .article-content :global(pre.astro-code) {
    background: var(--article-code-bg) !important;
    color: var(--article-code-text) !important;
  }

  .article-content :global(pre code) {
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
  }

  :global(html[data-theme='dark']) .article-content :global(pre.astro-code span[style*="#E1E4E8"]) {
    color: #c8d2dc !important;
  }

  :global(html[data-theme='dark']) .article-content :global(pre.astro-code span[style*="#9ECBFF"]) {
    color: #83add8 !important;
  }

  :global(html[data-theme='dark']) .article-content :global(pre.astro-code span[style*="#79B8FF"]) {
    color: #6f9ed0 !important;
  }

  :global(html[data-theme='dark']) .article-content :global(pre.astro-code span[style*="#B392F0"]) {
    color: #a58ad9 !important;
  }

  :global(html[data-theme='dark']) .article-content :global(pre.astro-code span[style*="#F97583"]) {
    color: #d46f7d !important;
  }

  .article-content :global(blockquote) {
    padding: 14px 0 14px 22px;
    border-left: 3px solid var(--oc-accent-primary);
    color: var(--oc-text-primary);
