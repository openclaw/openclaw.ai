---
import Layout from '../../layouts/Layout.astro';
import SiteTopbar from '../../components/SiteTopbar.astro';
import { render } from 'astro:content';
import { getPublishedBlogPosts } from '../../lib/blog';
import { getCachedXAvatarSrc, getInitialsAvatarSrc } from '../../lib/avatars';

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getPublishedBlogPosts();
const { Content, headings } = await render(post);

type AuthorLink = { label: string; url: string };
type Author = { name: string; handle?: string; url?: string; links?: AuthorLink[]; avatar?: string };
const authors: Author[] = post.data.authors
  ? post.data.authors
  : post.data.author
    ? [{
        name: post.data.author,
        handle: post.data.authorHandle,
        url: post.data.authorUrl,
        avatar: post.data.authorAvatar,
      }]
    : [];

function getAuthorAvatar(author: Author): string {
  return author.avatar ?? (author.handle ? getCachedXAvatarSrc(author.handle, author.name, 88) : '/openclaw-logo-text-dark.png');
}

function getAuthorLinks(author: Author): AuthorLink[] {
  if (author.links?.length) return author.links;
  const url = author.url ?? (author.handle ? `https://x.com/${author.handle}` : null);
  if (!url) return [];
  return [{
    label: author.handle ? `@${author.handle}` : new URL(url).hostname.replace(/^www\./, ''),
    url,
  }];
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function estimateReadTime(content: string): string {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 220))} min read`;
}

const toc = headings
  .filter((heading) => heading.depth === 2 || heading.depth === 3)
  .map((heading) => ({
    level: heading.depth,
    title: heading.text,
    id: heading.slug,
  }))
  .slice(0, 16);

const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => ({
    post: candidate,
    score: candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
  }))
  .sort((a, b) => b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf())
  .slice(0, 3)
  .map((item) => item.post);

const postUrl = `https://openclaw.ai/blog/${post.id}`;
---

<Layout title={`${post.data.title} - OpenClaw Blog`} description={post.data.description}>
  <SiteTopbar active="blog" />
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="reader-shell">
    <aside class="reader-sidebar" aria-label="Blog navigation">
      <a class="back-link" href="/blog">All posts</a>
      <div class="side-card">
        <p class="side-kicker">Filed under</p>
        <div class="side-tags">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </div>
      <div class="side-card">
        <p class="side-kicker">Related docs</p>
        <a href="https://docs.openclaw.ai/gateway/security" target="_blank" rel="noopener">Security</a>
        <a href="https://docs.openclaw.ai/plugins" target="_blank" rel="noopener">Plugins</a>
        <a href="https://docs.openclaw.ai/providers/openai" target="_blank" rel="noopener">OpenAI</a>
      </div>
    </aside>

    <article class="article">
      <header class="article-header">
        <p class="article-kicker">OpenClaw blog</p>
        <h1>{post.data.title}</h1>
        <p class="dek">{post.data.description}</p>

        {post.data.image && (
          <img src={post.data.image} alt={post.data.title} class="article-header-image" />
        )}

        <div class="article-meta">
          <div class="authors-container">
            {authors.map((author) => (
              <div class="author-info">
                <img
                  src={getAuthorAvatar(author)}
                  alt={author.name}
                  class="author-avatar"
                  loading="lazy"
                  onerror={`this.src='${getInitialsAvatarSrc(author.name, 88)}'`}
                />
                <div class="author-details">
                  <span class="author-name">{author.name}</span>
                  {getAuthorLinks(author).length > 0 && (
                    <div class="author-links">
                      {getAuthorLinks(author).map((link) => (
                        <a href={link.url} class="author-handle" target="_blank" rel="noopener">{link.label}</a>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
          <div class="meta-right">
            <span>{formatDate(post.data.date)}</span>
            <span>{estimateReadTime(post.body || '')}</span>
          </div>
        </div>
      </header>

      <div class="article-content" data-article-content>
        <Content />
      </div>

      <footer class="article-footer">
        <section class="share-section">
          <span>Share this post</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}&via=openclaw`} target="_blank" rel="noopener">
            X
          </a>
          <a href={`https://news.ycombinator.com/submitlink?u=${encodeURIComponent(postUrl)}&t=${encodeURIComponent(post.data.title)}`} target="_blank" rel="noopener">
            Hacker News
          </a>
        </section>

        {relatedPosts.length > 0 && (
          <section class="related-posts">
            <h2>Keep reading</h2>
            <div>
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.id}`}>
                  <span>{formatDate(related.data.date)}</span>
                  <strong>{related.data.title}</strong>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="cta-box">
          <div>
            <h2>Build from the docs</h2>
            <p>Install, configure, and harden OpenClaw with the same reading layout.</p>
          </div>
          <a href="https://docs.openclaw.ai/start/getting-started" target="_blank" rel="noopener">Open docs</a>
        </section>
      </footer>
    </article>

    {toc.length > 0 && (
      <aside class="reader-toc" aria-label="On this page">
        <h2>On this page</h2>
        {toc.map((item) => (
          <a class:list={[`toc-l${item.level}`]} href={`#${item.id}`}>{item.title}</a>
        ))}
      </aside>
    )}
  </main>

</Layout>

<style>
  .stars {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 24px 34px, rgba(255,255,255,0.65), transparent),
      radial-gradient(1px 1px at 110px 80px, rgba(0,229,204,0.42), transparent),
      radial-gradient(1px 1px at 210px 42px, rgba(255,77,77,0.36), transparent);
    background-size: 290px 180px;
    opacity: 0.34;
  }

  .nebula {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(720px circle at 9% 4%, rgba(255, 77, 77, 0.10), transparent 54%),
      radial-gradient(660px circle at 86% 0%, rgba(0, 229, 204, 0.07), transparent 56%);
  }

  .reader-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 220px minmax(0, 760px) 230px;
    gap: 58px;
    max-width: 1420px;
    margin: 0 auto;
    padding: 54px 32px 96px;
  }

  .reader-sidebar,
  .reader-toc {
    position: sticky;
    top: 92px;
    align-self: start;
    max-height: calc(100vh - 120px);
    overflow: auto;
  }

  .back-link,
  .side-card a,
  .reader-toc a {
    color: var(--text-muted);
    font-weight: 650;
    text-decoration: none;
  }

  .back-link:hover,
  .side-card a:hover,
  .reader-toc a:hover {
    color: var(--text-primary);
  }

  .side-card {
    margin-top: 26px;
    padding-top: 22px;
    border-top: 1px solid var(--border-subtle);
  }

  .side-card a {
    display: block;
    padding: 6px 0;
    font-size: 0.9rem;
  }

  .side-kicker,
  .article-kicker,
  .reader-toc h2 {
    margin: 0 0 12px;
    color: var(--coral-bright);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .side-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .side-tags span {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 9px;
    border: 1px solid color-mix(in srgb, var(--cyan-bright) 26%, var(--border-subtle));
    border-radius: 999px;
    background: var(--surface-cyan-soft);
    color: var(--cyan-bright);
    font-size: 0.72rem;
    font-weight: 750;
  }

  .article {
    min-width: 0;
  }

  .article-header {
    margin-bottom: 42px;
  }

  .article h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2.35rem, 6vw, 4.25rem);
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: 0;
  }

  .dek {
    margin-top: 18px;
    max-width: 700px;
    color: var(--text-secondary);
    font-size: 1.18rem;
    line-height: 1.65;
  }

  .article-header-image {
    display: block;
    width: 100%;
    max-height: 360px;
    object-fit: contain;
    margin-top: 28px;
    border-radius: 8px;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 30px;
    padding-top: 22px;
    border-top: 1px solid var(--border-subtle);
  }

  .authors-container {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--border-subtle);
    background: var(--bg-elevated);
  }

  .author-details {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .author-name {
    color: var(--text-primary);
    font-weight: 750;
  }

  .author-links {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
  }

  .author-handle {
    color: var(--coral-bright);
    font-size: 0.85rem;
    text-decoration: none;
  }

  .meta-right {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.84rem;
  }

  .article-content {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.82;
  }

  .article-content :global(p:first-child) {
    color: var(--text-primary);
    font-size: 1.18rem;
    line-height: 1.72;
  }

  .article-content :global(p),
  .article-content :global(ul),
  .article-content :global(ol),
  .article-content :global(blockquote),
  .article-content :global(pre),
  .article-content :global(figure) {
    margin: 0 0 1.25em;
  }

  .article-content :global(h2) {
    margin: 2.6em 0 0.65em;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 1.62rem;
    line-height: 1.16;
    letter-spacing: 0;
  }

  .article-content :global(h3) {
    margin: 1.9em 0 0.55em;
    color: var(--text-primary);
    font-size: 1.12rem;
    line-height: 1.3;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.35rem;
  }

  .article-content :global(li) {
    margin: 0.25em 0;
  }

  .article-content :global(li::marker) {
    color: var(--coral-bright);
  }

  .article-content :global(strong) {
    color: var(--text-primary);
    font-weight: 800;
  }

  .article-content :global(a) {
    color: var(--coral-bright);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(a:hover) {
    color: var(--cyan-bright);
  }

  .article-content :global(code) {
    padding: 0.08em 0.36em;
    border: 1px solid var(--border-subtle);
    border-radius: 5px;
    background: var(--bg-elevated);
    color: var(--cyan-bright);
    font-family: var(--font-mono);
    font-size: 0.88em;
  }

  .article-content :global(pre) {
    overflow: auto;
    padding: 14px 16px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: var(--bg-elevated);
  }

  .article-content :global(pre code) {
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
  }

  .article-content :global(blockquote) {
    padding: 14px 0 14px 22px;
    border-left: 3px solid var(--coral-bright);
    color: var(--text-primary);
    font-style: italic;
  }

  .article-content :global(hr) {
    margin: 30px 0;
    border: 0;
    border-top: 1px solid var(--border-subtle);
  }

  .article-content :global(.evidence-figure) {
    margin: 36px 0 40px;
  }

  .article-content :global(.evidence-figure img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .article-content :global(.evidence-figure figcaption) {
    margin-top: 12px;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.55;
    text-align: center;
  }

  .reader-toc a {
    display: block;
    padding: 6px 0;
    font-size: 0.9rem;
    line-height: 1.42;
  }

  .reader-toc .toc-l3 {
    padding-left: 12px;
    font-size: 0.84rem;
  }

  .article-footer {
    margin-top: 64px;
    padding-top: 28px;
    border-top: 1px solid var(--border-subtle);
  }

  .share-section {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .share-section a,
  .cta-box a {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 12px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: var(--surface-card);
    color: var(--text-primary);
    font-weight: 750;
    text-decoration: none;
  }

  .share-section a:hover,
  .cta-box a:hover {
    border-color: var(--coral-bright);
    color: var(--coral-bright);
  }

  .related-posts {
    margin-top: 38px;
  }

  .related-posts h2,
  .cta-box h2 {
    margin: 0 0 14px;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 1.28rem;
    letter-spacing: 0;
  }

  .related-posts div {
    display: grid;
    gap: 10px;
  }

  .related-posts a {
    display: grid;
    gap: 4px;
    padding: 14px 0;
    border-top: 1px solid var(--border-subtle);
    color: inherit;
    text-decoration: none;
  }

  .related-posts a span {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .related-posts a strong {
    color: var(--text-primary);
  }

  .related-posts a:hover strong {
    color: var(--coral-bright);
  }

  .cta-box {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 38px;
    padding: 26px 28px;
    border: 1px solid color-mix(in srgb, var(--cyan-bright) 30%, var(--border-subtle));
    border-radius: 8px;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--cyan-bright) 14%, transparent), transparent 42%),
      linear-gradient(90deg, color-mix(in srgb, var(--coral-bright) 10%, transparent), transparent 34%),
      var(--surface-card-strong);
    box-shadow:
      inset 0 1px 0 var(--surface-inset-highlight),
      0 20px 54px color-mix(in srgb, var(--cyan-bright) 10%, transparent);
  }

  .cta-box::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--coral-bright), var(--cyan-bright));
  }

  .cta-box > * {
    position: relative;
    z-index: 1;
  }

  .cta-box p {
    margin: 0;
    color: color-mix(in srgb, var(--text-primary) 62%, var(--text-secondary));
  }

  .cta-box a {
    min-height: 42px;
    padding: 0 18px;
    border-color: color-mix(in srgb, var(--cyan-bright) 42%, var(--border-subtle));
    background: color-mix(in srgb, var(--cyan-bright) 14%, var(--surface-card-strong));
    box-shadow: inset 0 1px 0 var(--surface-inset-highlight);
  }

  .cta-box a:hover {
    border-color: var(--cyan-bright);
    color: var(--cyan-bright);
    background: color-mix(in srgb, var(--cyan-bright) 18%, var(--surface-card-strong));
  }

  @media (max-width: 1080px) {
    .reader-shell {
      grid-template-columns: 180px minmax(0, 1fr);
      gap: 34px;
    }

    .reader-toc {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .reader-shell {
      display: block;
      padding: 34px 20px 76px;
    }

    .reader-sidebar {
      position: static;
      margin-bottom: 28px;
    }

    .side-card {
      display: none;
    }

    .article h1 {
      font-size: clamp(2.2rem, 12vw, 3.2rem);
    }

    .article-meta,
    .cta-box {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
