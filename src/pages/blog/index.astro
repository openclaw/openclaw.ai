---
import Layout from '../../layouts/Layout.astro';
import SiteTopbar from '../../components/SiteTopbar.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { getPublishedBlogPosts } from '../../lib/blog';
import { resolveAuthorProfile, type BlogAuthor } from '../../lib/authors';

const posts = await getPublishedBlogPosts();
const [featured, ...rest] = posts;
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].slice(0, 10);
const assignedTagAnchors = new Set<string>();

function claimPostAnchors(post: (typeof posts)[number]): string[] {
  const anchors = post.data.tags.filter((candidate) => !assignedTagAnchors.has(candidate));
  anchors.forEach((tag) => assignedTagAnchors.add(tag));
  return anchors;
}

const postAnchors = new Map(posts.map((post) => [post.id, claimPostAnchors(post)]));

function formatTagLabel(tag: string): string {
  const overrides: Record<string, string> = {
    clawhub: 'ClawHub',
    codex: 'Codex',
    openai: 'OpenAI',
  };
  return overrides[tag] ?? tag.split('-').map((part) => part.charAt(0).toUpperCase() + part.slice(1)).join('-');
}

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function estimateReadTime(content: string): string {
  const words = content.split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.ceil(words / 220))} min read`;
}

function firstAuthor(post: (typeof posts)[number]): BlogAuthor {
  return resolveAuthorProfile(post.data.authors?.[0] ?? {
    name: post.data.author ?? 'OpenClaw Team',
    handle: post.data.authorHandle,
    url: post.data.authorUrl,
    avatar: post.data.authorAvatar,
  });
}
---

<Layout title="Blog - OpenClaw" description="OpenClaw updates, security notes, release context, and product essays.">
  <SiteTopbar active="blog" />

  <main class="shell">
    <div class="rail">
      <header class="blog-head">
        <p class="eyebrow">OpenClaw blog</p>
        <h1>What we’re building, fixing, and learning.</h1>
        <p class="lede">
          Security writeups, release context, model/runtime notes, and the occasional lobster-shaped aside.
        </p>
        <nav class="tag-row" aria-label="Browse by topic">
          <a class="tag-link active" href="/blog">Latest</a>
          {tags.map((tag) => <a class="tag-link" href={`/blog#${tag}`}>{formatTagLabel(tag)}</a>)}
        </nav>
      </header>

      <section class="posts">
        {featured && postAnchors.get(featured.id)?.map((tag) => <span id={tag} class="tag-anchor" aria-hidden="true"></span>)}
        {featured && (
          <a class="featured-post oc-card" href={`/blog/${featured.id}`}>
            <div class="post-meta">
              <span class="post-date">{formatDate(featured.data.date)}</span>
              <span>{firstAuthor(featured).name}</span>
              <span>{estimateReadTime(featured.body || '')}</span>
            </div>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.description}</p>
            <div class="post-tags">
              {featured.data.tags.map((tag) => <span>{formatTagLabel(tag)}</span>)}
            </div>
          </a>
        )}

        <div class="post-list">
          {rest.map((post) => (
            <>
              {postAnchors.get(post.id)?.map((tag) => <span id={tag} class="tag-anchor" aria-hidden="true"></span>)}
              <a class="post-row" href={`/blog/${post.id}`}>
                <div class="post-date">{formatDate(post.data.date)}</div>
                <div class="post-body">
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <div class="row-footer">
                    <span>{firstAuthor(post).name}</span>
                    <span>·</span>
                    <span>{estimateReadTime(post.body || '')}</span>
                    {post.data.tags.slice(0, 3).map((tag) => <span class="tag">{formatTagLabel(tag)}</span>)}
                  </div>
                </div>
              </a>
            </>
          ))}
        </div>
      </section>

      <SiteFooter current="blog" spacing="roomy" />
    </div>
  </main>
</Layout>

<style>
  .shell {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .rail {
    width: 100%;
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 var(--oc-space-7);
    border-left: 1px solid var(--oc-border-subtle);
    border-right: 1px solid var(--oc-border-subtle);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-head {
    padding: 56px 0 0;
  }

  .eyebrow {
    color: var(--oc-accent-primary);
    font-family: var(--oc-font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .blog-head h1 {
    max-width: 640px;
    margin: 14px 0 14px;
    font-family: var(--oc-font-display);
    font-size: clamp(1.9rem, 4vw, 2.7rem);
    font-weight: 600;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--oc-text-primary);
  }

  .lede {
    max-width: 620px;
    color: var(--oc-text-muted);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--oc-space-2);
    margin-top: 26px;
    padding-bottom: 26px;
    border-bottom: 1px solid var(--oc-border-subtle);
  }

  .tag-link {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border: 1px solid var(--oc-border-subtle);
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .tag-link:hover,
  .tag-link.active {
    background: var(--oc-bg-surface);
    color: var(--oc-text-primary);
  }

  .tag-link.active {
    color: var(--oc-accent-primary);
  }

  .posts {
    padding: 40px 0 var(--oc-space-5);
  }

  .featured-post {
    display: block;
    margin-bottom: 40px;
    padding: 30px 28px;
    border: 1px solid var(--oc-border-subtle);
    background: var(--oc-bg-surface);
    color: inherit;
    box-shadow: none;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .featured-post:hover {
    background: var(--oc-bg-elevated);
  }

  .featured-post:hover h2,
  .post-row:hover h2 {
    color: var(--oc-accent-primary);
  }

  .post-meta,
  .row-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.74rem;
    font-weight: 500;
  }

  .post-date {
    color: var(--oc-accent-primary);
  }

  .featured-post h2,
  .post-row h2 {
    margin: var(--oc-space-3) 0 10px;
    font-family: var(--oc-font-display);
    color: var(--oc-text-primary);
    letter-spacing: -0.015em;
    transition: color 0.16s ease;
  }

  .featured-post h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    line-height: 1.2;
  }

  .featured-post p,
  .post-row p {
    max-width: 720px;
    color: var(--oc-text-secondary);
    font-size: 0.95rem;
    line-height: 1.68;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--oc-space-2);
    margin-top: 18px;
  }

  .post-tags span,
  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0 9px;
    border: 1px solid var(--oc-border-subtle);
    color: var(--oc-text-secondary);
    font-family: var(--oc-font-mono);
    font-size: 0.7rem;
    font-weight: 500;
  }

  .post-list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--oc-border-subtle);
  }

  .tag-anchor {
    display: block;
    scroll-margin-top: 90px;
  }

  .post-row {
    display: grid;
    grid-template-columns: 128px minmax(0, 1fr);
    gap: var(--oc-space-5);
    padding: 26px 0;
    border-bottom: 1px solid var(--oc-border-subtle);
    color: inherit;
    text-decoration: none;
  }

  .post-row .post-date {
    color: var(--oc-text-muted);
    font-family: var(--oc-font-mono);
    font-size: 0.78rem;
    padding-top: 3px;
  }

  .post-row h2 {
    margin-top: 0;
    font-size: 1.2rem;
    line-height: 1.3;
  }

  .row-footer {
    margin-top: var(--oc-space-3);
  }

  @media (max-width: 760px) {
    .rail {
      padding: 0 20px;
      border-left: none;
      border-right: none;
    }

    .blog-head {
      padding-top: 40px;
    }

    .tag-row {
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 20px;
    }

    .tag-link {
      flex: 0 0 auto;
    }

    .featured-post {
      padding: 22px 20px;
    }

    .post-row {
      display: block;
    }

    .post-row .post-date {
      margin-bottom: var(--oc-space-2);
    }
  }
</style>
