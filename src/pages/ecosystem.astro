---
import Layout from '../layouts/Layout.astro';
import SiteTopbar from '../components/SiteTopbar.astro';
import { siGithub } from 'simple-icons';

const siIcon = (icon: any) => icon.path;

// Color palette anchored to the site's coral / cyan / amber language.
const CORAL = '#FF6F4D';
const CORAL_DEEP = '#E0492A';
const CYAN = '#00E5CC';
const CYAN_DEEP = '#1AA9C9';
const AMBER = '#FFB347';
const VIOLET = '#A876FF';
