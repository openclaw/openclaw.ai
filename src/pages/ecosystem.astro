  Lobster: 'https://docs.openclaw.ai/tools/lobster',
  discrawl: 'https://discrawl.sh',
  gitcrawl: 'https://gitcrawl.sh',
  acpx: 'https://acpx.sh',
  mcporter: 'https://mcporter.sh',
  Tachikoma: 'https://tachikoma.build',
  clawpatch: 'https://clawpatch.ai',
  Peekaboo: 'https://peekaboo.sh',
  AXorcist: 'https://axorcist.dev',
  imsg: 'https://imsg.sh',
  wacli: 'https://wacli.sh',
  gogcli: 'https://gogcli.sh',
