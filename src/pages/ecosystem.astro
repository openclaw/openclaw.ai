  },
  {
    id: 'crawlers',
    title: 'Local-First Crawlers',
    tagline: 'Mirror your data — Discord, Slack, GitHub, WhatsApp, Notion — into a queryable SQLite archive on your laptop.',
    items: crawlers,
  },
  {
    id: 'infra',
    title: 'Agent Infrastructure & SDKs',
    tagline: 'The plumbing that other claws are built on. Protocols, models, benchmarks, skills.',
    items: infra,
  },
  {
    id: 'typescript-libraries',
    title: 'TypeScript Libraries',
    tagline: 'Small runtime packages for Node agents: filesystem boundaries, proxy routing, media codecs, and image pipelines.',
    items: typeScriptLibraries,
