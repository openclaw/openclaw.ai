    desc: 'Warm a sandbox, sync the diff, run the suite. Disposable dev boxes.',
    repo: 'https://github.com/openclaw/crabbox',
  },
  {
    name: 'Octopool',
    icon: 'lucide:network',
    color: VIOLET,
    desc: 'Shared, org-authenticated GitHub read relay and cache. One token to rule them all.',
