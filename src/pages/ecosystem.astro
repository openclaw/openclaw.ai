const generatedBannerSlugs = new Set([
  'clawsweeper',
  'crabbox',
  'octopool',
  'crabfleet',
  'clawhub',
  'clickclack',
  'lobster',
  'discrawl',
  'gitcrawl',
  'slacrawl',
  'wacrawl',
  'notcrawl',
  'telecrawl',
  'graincrawl',
  'crawlkit',
  'crawlbar',
  'acpx',
  'mcporter',
  'tachikoma',
  'clawpatch',
  'clawbench',
  'agent-skills',
  'plugin-inspector',
  'cookbook',
  'peekaboo',
  'axorcist',
  'imsg',
  'wacli',
  'remindctl',
  'gogcli',
  'spogo',
  'songsee',
  'goplaces',
]);

function projectSlug(name: string) {
  return name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

function bannerSrc(project: Project) {
  const slug = projectSlug(project.name);
  return `/ecosystem/banners/${slug}.${generatedBannerSlugs.has(slug) ? 'png' : 'svg'}`;
}

function siteUrl(project: Project) {
  return siteByName[project.name] ?? project.site;
}

function logoSrc(project: Project) {
  return logoByName[project.name];
}

---

<Layout title="Ecosystem — OpenClaw">
  <SiteTopbar active="ecosystem" />
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="hero">
      <p class="eyebrow">The OpenClaw ecosystem</p>
      <h1 class="title">A whole reef of claws.</h1>
      <p class="description">
        OpenClaw is more than the assistant. It is a federation of ~70 open source
        projects — hosted agents, local-first crawlers, SDKs, skill registries, and
        native tooling — that share a runtime, a protocol, and a sense of humor.
      </p>
      <nav class="anchor-row" aria-label="Section shortcuts">
        {sections.map((s) => (
          <a href={`#${s.id}`} class="anchor-chip">{s.title}</a>
        ))}
        <a href="#more" class="anchor-chip muted">Everything else</a>
      </nav>
    </header>

    {sections.map((section) => (
      <section class="section" id={section.id}>
        <h2 class="section-title">
          <span class="claw-accent">⟩</span> {section.title}
        </h2>
        <p class="section-desc">{section.tagline}</p>
        <div class="grid">
          {section.items.map((p) => (
            <article class="card" style={`--accent: ${p.color}`}>
              <div class="card-art">
                <img
                  class="card-banner"
                  src={bannerSrc(p)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
                <span class="logo-badge">
                  {logoSrc(p) ? (
                    <img src={logoSrc(p)} alt="" loading="lazy" decoding="async" />
                  ) : (
                    <span class="generated-logo">
                      <img src={bannerSrc(p)} alt="" loading="lazy" decoding="async" />
                    </span>
                  )}
                </span>
              </div>
              <h3 class="card-name">
                <a class="card-stretch" href={siteUrl(p) ?? p.repo} target="_blank" rel="noopener">
                  {p.name}
                </a>
              </h3>
              <p class="card-desc">{p.desc}</p>
              <div class="card-links">
                {siteUrl(p) && (
                  <a href={siteUrl(p)} target="_blank" rel="noopener" class="card-link">Site ↗</a>
                )}
                <a href={p.repo} target="_blank" rel="noopener" class="card-link" aria-label={`${p.name} on GitHub`}>
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor" aria-hidden="true">
                    <path d={siIcon(siGithub)} />
                  </svg>
                  Repo
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="section more-section" id="more">
      <h2 class="section-title">
        <span class="claw-accent">⟩</span> Everything else
      </h2>
      <p class="section-desc">
        The rest of the public surface: NixOS modules, runtime libraries, infra,
        experiments, docs source. Click any to dive in.
      </p>
      <details class="more-details">
        <summary>
          <span class="summary-label">Show {everythingElse.length} more projects</span>
          <span class="summary-chevron" aria-hidden="true">⌄</span>
        </summary>
        <div class="grid more-grid">
          {everythingElse.map((p) => (
            <article class="card card-compact" style={`--accent: ${p.color}`}>
              <div class="card-art">
                <img
                  class="card-banner"
                  src={bannerSrc(p)}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
                <span class="logo-badge">
                  {logoSrc(p) ? (
                    <img src={logoSrc(p)} alt="" loading="lazy" decoding="async" />
                  ) : (
                    <span class="generated-logo">
                      <img src={bannerSrc(p)} alt="" loading="lazy" decoding="async" />
                    </span>
                  )}
                </span>
              </div>
              <h3 class="card-name">
                <a class="card-stretch" href={siteUrl(p) ?? p.repo} target="_blank" rel="noopener">
                  {p.name}
                </a>
              </h3>
              <p class="card-desc">{p.desc}</p>
            </article>
          ))}
        </div>
      </details>
    </section>

    <section class="cta-section">
      <h2 class="cta-title">Build with us</h2>
      <p class="cta-desc">
        Everything above is open source. Read an RFC, file an issue, ship a skill to ClawHub.
      </p>
      <div class="cta-row">
        <a href="https://github.com/openclaw" target="_blank" rel="noopener" class="cta-button cta-primary">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d={siIcon(siGithub)} />
          </svg>
          Browse the org
        </a>
        <a href="https://clawhub.ai" target="_blank" rel="noopener" class="cta-button cta-secondary">
          ClawHub registry →
        </a>
      </div>
    </section>

    <footer class="footer">
      <nav class="footer-nav">
        <a href="/">Home</a>
        <span class="footer-separator">·</span>
        <a href="/integrations">Integrations</a>
        <span class="footer-separator">·</span>
        <a href="/blog">Blog</a>
        <span class="footer-separator">·</span>
        <a href="/showcase">Showcase</a>
        <span class="footer-separator">·</span>
        <a href="/press">Press</a>
