---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SiteTopbar from '../components/SiteTopbar.astro';
import SiteFooter from '../components/SiteFooter.astro';
import testimonials from '../data/testimonials.json';
import communityBuilds from '../data/community-builds.json';
import pressArticles from '../data/press.json';
import footerAsciinator from '../data/footer-asciinator.html?raw';
import {
  bottomIntegrationRail,
  integrationScrubberTickCount,
  topIntegrationRail,
} from '../data/homepage-integrations';
import { getPublishedBlogPosts } from '../lib/blog';
import { renderAsciiAurora } from '../lib/ascii-aurora';
import { getCachedXAvatarSrc, getInitialsAvatarSrc } from '../lib/avatars';
import { sanitizeUrl } from '../lib/sanitize-url';
import { siX } from 'simple-icons';

const blogPosts = await getPublishedBlogPosts();
const [latestPost] = blogPosts;
const recentBlogPosts = blogPosts.slice(1, 3);
const integrationScrubberTicks = Array.from({ length: integrationScrubberTickCount });

const half = Math.ceil(testimonials.length / 2);
const topRow = testimonials.slice(0, half);
const bottomRow = testimonials.slice(half);
const row1 = [...topRow, ...topRow];
const row2 = [...bottomRow, ...bottomRow];
const pixelsPerItem = 336;
const pixelsPerSecond = 50;
const duration1 = (row1.length / 2 * pixelsPerItem) / pixelsPerSecond;
const duration2 = (row2.length / 2 * pixelsPerItem) / pixelsPerSecond;
const featuredBuilds = communityBuilds.slice(0, 4);
const featuredPress = pressArticles.slice(0, 4).map((article) => {
  let favicon: string | null = null;
  try {
    favicon = `/press/icons/${new URL(article.url).hostname.replace(/^www\./, '')}.png`;
  } catch {
    // leave outlets without a parseable URL logo-less
  }
  return { ...article, favicon };
});

function postThumb(post: (typeof blogPosts)[number]): string | null {
  if (post.data.ogImage?.src) return post.data.ogImage.src;
  if (post.data.coverImage) return post.data.coverImage;
  if (post.data.image) return post.data.image;
  const body = post.body ?? '';
  const md = body.match(/!\[[^\]]*\]\((\/[^)\s]+)/);
  if (md) return md[1];
  const html = body.match(/<img[^>]+src="(\/[^"]+)"/);
  return html ? html[1] : null;
}

function formatBlogDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

const asciiAurora = renderAsciiAurora();
---

<Layout title="OpenClaw — Personal AI Assistant">
  <SiteTopbar active="home" />

  <main class="container">
    <!-- Hero: full-bleed dither arcs, content below -->
    <header class="hero">
      <div class="hero-art" aria-hidden="true"><pre>{asciiAurora}</pre></div>
      <div class="hero-content">
        <svg class="hero-mark" viewBox="0 0 120 120" fill="none" aria-hidden="true">
          <!-- Lobster Claw Silhouette -->
          <path d="M60 10 C30 10 15 35 15 55 C15 75 30 95 45 100 L45 110 L55 110 L55 100 C55 100 60 102 65 100 L65 110 L75 110 L75 100 C90 95 105 75 105 55 C105 35 90 10 60 10Z" fill="url(#lobster-gradient)"/>
          <!-- Left Claw -->
          <path d="M20 45 C5 40 0 50 5 60 C10 70 20 65 25 55 C28 48 25 45 20 45Z" fill="url(#lobster-gradient)"/>
          <!-- Right Claw -->
          <path d="M100 45 C115 40 120 50 115 60 C110 70 100 65 95 55 C92 48 95 45 100 45Z" fill="url(#lobster-gradient)"/>
          <!-- Antenna -->
          <path d="M45 15 Q35 5 30 8" stroke="var(--oc-accent-primary)" stroke-width="2" stroke-linecap="round"/>
          <path d="M75 15 Q85 5 90 8" stroke="var(--oc-accent-primary)" stroke-width="2" stroke-linecap="round"/>
          <!-- Eyes -->
          <circle cx="45" cy="35" r="6" fill="#101012"/>
          <circle cx="75" cy="35" r="6" fill="#101012"/>
          <circle cx="46" cy="34" r="2" fill="var(--oc-accent-secondary)"/>
          <circle cx="76" cy="34" r="2" fill="var(--oc-accent-secondary)"/>
          <defs>
            <linearGradient id="lobster-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="var(--logo-gradient-start)"/>
              <stop offset="100%" stop-color="var(--logo-gradient-end)"/>
            </linearGradient>
          </defs>
        </svg>
        <p class="hero-eyebrow">Open source · Runs on your machine</p>

        <h1 class="title">The AI that <em>really</em> does things.</h1>

        <p class="description">
          Organizes your inbox, sends emails, manages your calendar, checks you in for flights.<br/>
          All from WhatsApp, Telegram, or any chat app you already use.
        </p>

        <div class="hero-actions">
          <a href="#quickstart" class="hero-cta oc-action oc-action-primary">Get started</a>
          <a href="https://docs.openclaw.ai/" target="_blank" rel="noopener" class="hero-cta hero-cta-ghost oc-action oc-action-ghost">Read the docs</a>
        </div>
      </div>
    </header>

    <div class="rail">
    <!-- Quick Start -->
    <section id="quickstart" class="quickstart" data-quickstart>
      <SectionHeader title="Quick Start" />
      <div class="code-block">
        <div class="code-header">
          <span class="code-label">install</span>
          <div class="mode-switch">
            <button type="button" class="mode-btn active" data-mode="oneliner">One-liner</button>
            <button type="button" class="mode-btn" data-mode="quick">npm</button>
            <button type="button" class="mode-btn" data-mode="hackable">Hackable</button>
            <button type="button" class="mode-btn" data-mode="macos">Apps</button>
          </div>
          <div class="pm-switch" id="pm-switch" hidden>
            <button type="button" class="pm-btn active" data-pm="npm">npm</button>
            <button type="button" class="pm-btn" data-pm="pnpm">pnpm</button>
          </div>
          <div class="hackable-switch" id="hackable-switch" hidden>
            <button type="button" class="hackable-btn active" data-hackable="installer">installer</button>
            <button type="button" class="hackable-btn" data-hackable="pnpm">pnpm</button>
          </div>
          <div class="os-switch" id="os-switch" hidden>
            <button type="button" class="os-btn active" data-os="unix">macOS & Linux</button>
            <button type="button" class="os-btn" data-os="windows">Windows</button>
          </div>
          <div class="beta-switch" id="beta-switch">
            <button type="button" class="beta-btn" id="beta-btn" data-beta="false">
              <span class="beta-label">β</span>
              <span class="beta-text">Beta</span>
            </button>
          </div>
          <div class="switch-placeholder" id="switch-placeholder" aria-hidden="true" hidden></div>
        </div>
        <div id="code-oneliner" class="code-content">
          <div class="code-line comment" id="oneliner-comment"># Works everywhere. On macOS, first run may need an Administrator for Homebrew.</div>
          <div class="code-line cmd">
            <span class="code-prompt">$</span>
            <span class="os-cmd">curl -fsSL https://openclaw.ai/install.sh | bash</span>
            <button type="button" class="copy-line-btn" data-cmd="oneliner" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <div id="code-quick" class="code-content" hidden>
          <div class="code-line comment" id="quick-comment-install"># Install OpenClaw</div>
          <div class="code-line cmd">
            <span class="code-prompt">$</span>
            <span class="pm-install">npm i -g openclaw</span>
            <button type="button" class="copy-line-btn" data-cmd="install" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
          <div class="code-line comment" id="quick-comment-onboard"># Meet your lobster</div>
          <div class="code-line cmd">
            <span class="code-prompt">$</span>
            <span>openclaw onboard</span>
            <button type="button" class="copy-line-btn" data-cmd="onboard" title="Copy">
              <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
            </button>
          </div>
        </div>
        <div id="code-hackable" class="code-content" hidden>
          <div id="hackable-installer-content">
            <div class="code-line comment"># For those who read source code for fun</div>
            <div class="code-line cmd">
              <span class="code-prompt">$</span>
              <span class="os-cmd-hackable">curl -fsSL https://openclaw.ai/install.sh | bash -s -- --install-method git</span>
              <button type="button" class="copy-line-btn" data-cmd="hackable-installer" title="Copy">
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
          <div id="hackable-pnpm-content" hidden>
            <div class="code-line comment"># Source checkouts are pnpm workspaces</div>
            <div class="code-line cmd">
              <span class="code-prompt">$</span>
              <span>git clone https://github.com/openclaw/openclaw.git</span>
              <button type="button" class="copy-line-btn" data-cmd="clone" title="Copy">
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
            <div class="code-line cmd">
              <span class="code-prompt">$</span>
              <span>cd openclaw && corepack enable && pnpm install</span>
              <button type="button" class="copy-line-btn" data-cmd="build" title="Copy">
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
            <div class="code-line comment"># Run from source; bundled plugins use extensions/* deps</div>
            <div class="code-line cmd">
              <span class="code-prompt">$</span>
              <span>pnpm openclaw onboard</span>
              <button type="button" class="copy-line-btn" data-cmd="hackable-onboard" title="Copy">
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" hidden><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div id="code-macos" class="code-content" hidden>
          <div class="app-download-content">
            <div class="app-download-intro">
              <span class="app-download-tagline">Companion Apps (Beta)</span>
              <span class="app-download-subtitle">Native controls for the gateway, chat, setup, and node features.</span>
            </div>
            <div class="app-download-grid">
              <div class="app-download-card">
                <span class="app-download-platform">macOS</span>
                <a href="https://github.com/openclaw/openclaw/releases/latest" class="app-download-btn" target="_blank" rel="noopener">
                  <Icon icon="lucide:download" color="currentColor" size={20} />
                  Download macOS
                </a>
                <span class="app-download-meta">Requires macOS 15+ · Universal Binary</span>
              </div>
              <div class="app-download-card">
                <span class="app-download-platform">Windows Hub</span>
                <div class="windows-download-actions">
                  <a href="https://github.com/openclaw/openclaw/releases/latest/download/OpenClawCompanion-Setup-x64.exe" class="app-download-btn" target="_blank" rel="noopener">
                    <Icon icon="lucide:download" color="currentColor" size={20} />
                    Download x64
                  </a>
                  <a href="https://github.com/openclaw/openclaw/releases/latest/download/OpenClawCompanion-Setup-arm64.exe" class="app-download-btn app-download-btn-secondary" target="_blank" rel="noopener">
                    <Icon icon="lucide:download" color="currentColor" size={20} />
                    Download ARM64
                  </a>
                </div>
                <a class="app-download-meta" href="https://docs.openclaw.ai/platforms/windows" target="_blank" rel="noopener">Windows 10 20H2+ or Windows 11 · Tray, setup, chat, node mode</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <p class="quickstart-note">
        Works on macOS, Linux, and Windows. The one-liner installs Node.js and everything else for you. Switch later with <code>openclaw update --channel dev</code> or <code>openclaw update --channel stable</code>.
      </p>
    </section>

    <script>
      import { initHeroAurora } from '../scripts/home/hero-aurora';
      import { initIntegrationRail } from '../scripts/home/integration-rail';
      import { initQuickStart } from '../scripts/home/quickstart';

      const quickStart = document.querySelector<HTMLElement>("[data-quickstart]");
      if (quickStart) initQuickStart(quickStart);

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const aurora = document.querySelector<HTMLElement>('.hero-art pre');
      if (aurora) initHeroAurora(aurora, reducedMotion);

      const integrationRails = document.querySelector<HTMLElement>('[data-integration-rails]');
      if (integrationRails) initIntegrationRail(integrationRails, reducedMotion);
    </script>

    <!-- People -->
    <section class="testimonials">
      <SectionHeader
        title="What People Say"
        link={{ href: "/shoutouts", text: "View all" }}
      />
      <div class="testimonials-track">
        <div class="testimonials-row row-1" style={`--duration: ${duration1}s`}>
          {row1.map((t) => (
            <a href={sanitizeUrl(t.url)} target="_blank" rel="noopener" class="testimonial-card" tabindex="-1">
              <img
                src={getCachedXAvatarSrc(t.author, t.author, 88)}
                alt={t.author}
                class="testimonial-avatar"
                loading="lazy"
                onerror={`this.src='${getInitialsAvatarSrc(t.author, 88)}'`}
              />
              <div class="testimonial-content">
                <p class="testimonial-quote">"{t.quote}"</p>
                <span class="testimonial-author">@{t.author}</span>
              </div>
            </a>
          ))}
        </div>
        <div class="testimonials-row row-2" style={`--duration: ${duration2}s`}>
          {row2.map((t) => (
            <a href={sanitizeUrl(t.url)} target="_blank" rel="noopener" class="testimonial-card">
              <img
                src={getCachedXAvatarSrc(t.author, t.author, 88)}
                alt={t.author}
                class="testimonial-avatar"
                loading="lazy"
                onerror={`this.src='${getInitialsAvatarSrc(t.author, 88)}'`}
              />
              <div class="testimonial-content">
                <p class="testimonial-quote">"{t.quote}"</p>
                <span class="testimonial-author">@{t.author}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Latest -->
    {latestPost && (
      <section class="blog-preview">
        <div class="blog-preview-head">
          <div>
            <span class="blog-preview-kicker">Latest</span>
            <h2>Product notes with docs-level depth.</h2>
          </div>
          <a href="/blog" class="blog-preview-link">Read all <Icon icon="lucide:arrow-right" color="currentColor" size={11} class="link-arrow-icon" /></a>
        </div>

        <div class="blog-preview-grid">
          <a href={`/blog/${latestPost.id}`} class="blog-feature">
            <span class="blog-thumb">
              {postThumb(latestPost)
                ? <img src={postThumb(latestPost)} alt="" loading="lazy" />
                : <span class="blog-thumb-dither" aria-hidden="true"></span>}
            </span>
            <span class="blog-feature-badge">Latest</span>
            <span class="blog-date">{formatBlogDate(latestPost.data.date)}</span>
            <h3>{latestPost.data.title}</h3>
            <p>{latestPost.data.description}</p>
            <div class="blog-tags">
              {latestPost.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
            </div>
          </a>
          <div class="blog-recents">
            {recentBlogPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="blog-recent">
                <span class="blog-thumb">
                  {postThumb(post)
                    ? <img src={postThumb(post)} alt="" loading="lazy" />
                    : <span class="blog-thumb-dither" aria-hidden="true"></span>}
                </span>
                <span class="blog-date">{formatBlogDate(post.data.date)}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- What It Does -->
    <section class="features">
      <SectionHeader title="What It Does" />
      <div class="features-grid">
        <a href="https://docs.openclaw.ai/getting-started" target="_blank" rel="noopener" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:home" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Runs on Your Machine</h3>
          <p class="feature-desc">Mac, Windows, or Linux. Bring hosted, subscription-backed, gateway, or local models. State lives on your machine, not a vendor cloud.</p>
        </a>
        <a href="/integrations" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:message-circle" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Chat Where You Are</h3>
          <p class="feature-desc">Talk to it on WhatsApp, Telegram, Discord, Slack, Signal, iMessage, or any of its 29 channels. Works in DMs and group chats.</p>
        </a>
        <a href="https://docs.openclaw.ai/session" target="_blank" rel="noopener" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:brain" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Persistent Memory</h3>
          <p class="feature-desc">Remembers your preferences, projects, and people from one conversation to the next.</p>
        </a>
        <a href="https://docs.openclaw.ai/browser" target="_blank" rel="noopener" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:globe" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Browser Control</h3>
          <p class="feature-desc">It can browse the web, fill forms, and extract data from any site.</p>
        </a>
        <a href="https://docs.openclaw.ai/bash" target="_blank" rel="noopener" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:terminal" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Full System Access</h3>
          <p class="feature-desc">Read and write files, run shell commands, execute scripts. Full access or sandboxed—your choice.</p>
        </a>
        <a href="https://docs.openclaw.ai/skills" target="_blank" rel="noopener" class="feature-card">
          <div class="feature-icon"><Icon icon="lucide:puzzle" color="var(--oc-text-muted)" size={28} /></div>
          <h3 class="feature-title">Skills & Plugins</h3>
          <p class="feature-desc">Extend with community skills or build your own. It can even write its own.</p>
        </a>
      </div>
    </section>

    <!-- Integrations Preview -->
    <section class="integrations-preview" data-integration-rails>
      <div class="integrations-copy">
        <SectionHeader
          title="Works With Everything"
          link={{ href: "/integrations", text: "Explore integrations" }}
        />
      </div>

      <div class="integrations-railboard" aria-label="Supported integrations">
        <div class="integration-track integration-track-top" data-dir="left">
          {topIntegrationRail.map((p) => (
            <button type="button" class="integration-card" data-name={p.name} style={`--integration-color: ${p.color}`} aria-pressed="false">
              <span class="integration-icon">
                <Icon icon={p.icon} color="currentColor" size={30} />
              </span>
              <span class="integration-name">{p.name}</span>
              <span class="integration-meta">
                <span class="integration-kind">{p.kind}</span>
                <span class="integration-desc">{p.description}</span>
              </span>
            </button>
          ))}
        </div>

        <div class="integration-scrubber" aria-hidden="true">
          {integrationScrubberTicks.map((_, index) => (
            <span class:list={[index % 9 === 0 && 'major']}></span>
          ))}
        </div>

        <div class="integration-track integration-track-bottom" data-dir="right">
          {bottomIntegrationRail.map((p) => (
            <button type="button" class="integration-card" data-name={p.name} style={`--integration-color: ${p.color}`} aria-pressed="false">
              <span class="integration-icon">
                <Icon icon={p.icon} color="currentColor" size={30} />
              </span>
              <span class="integration-name">{p.name}</span>
              <span class="integration-meta">
                <span class="integration-kind">{p.kind}</span>
                <span class="integration-desc">{p.description}</span>
              </span>
            </button>
          ))}
        </div>
      </div>

      <div class="integrations-links">
        <a href="/integrations" class="integrations-link">Browse all integrations <Icon icon="lucide:arrow-right" color="currentColor" size={11} class="link-arrow-icon" /></a>
        <a href="/showcase" class="integrations-link">See what people built <Icon icon="lucide:arrow-right" color="currentColor" size={11} class="link-arrow-icon" /></a>
      </div>
    </section>

    <!-- Community Builds -->
    <section class="builds-section">
      <div class="builds-grid">
        <div class="builds-head-cell">
          <h2><span>What people are building.</span></h2>
          <p><span>Real OpenClaw workflows shared by the community.</span></p>
          <a href="/showcase" class="builds-head-cta">View showcase</a>
        </div>
        {featuredBuilds.map((build) => (
          <a href={sanitizeUrl(build.href)} target="_blank" rel="noopener" class="build-card">
            <div class="build-card-header">
              <span class="build-source">
                <svg class="build-source-icon" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d={siX.path} /></svg>
                THREAD
              </span>
