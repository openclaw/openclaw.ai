---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteTopbar from '../components/SiteTopbar.astro';
import {
  automationLinks,
  capabilities,
  catalogSnapshot,
  channels,
  communityGroups,
  companionNodes,
  featuredProviders,
  gatewayHosts,
  providerGroups,
  type CatalogStatus,
} from '../data/integrations';

const statusLabels: Record<CatalogStatus, string> = {
  'built-in': 'Bundled',
  included: 'Bundled',
  official: 'Official plugin',
  external: 'External plugin',
  community: 'Community',
  gateway: 'Gateway host',
  node: 'Companion node',
};
---

<Layout
  title="Integrations — OpenClaw"
  description="Connect OpenClaw to chat channels, model providers, tools, automation, companion apps, and community extensions."
>
  <SiteTopbar active="integrations" />
  <div class="stars" aria-hidden="true"></div>

  <main class="page-shell">
    <header class="hero">
      <h1 class="hero-title">Integrations</h1>
      <p class="hero-lede">
        Connect OpenClaw to the chats, models, tools, and devices you already use.
      </p>
      <p class="hero-copy">
        Bring API keys, sign in with supported subscriptions, route through a gateway,
        or run models locally. Extend the runtime with official plugins and community skills.
      </p>
      <div class="hero-actions">
        <a href="https://docs.openclaw.ai/" target="_blank" rel="noopener" class="action action-primary">
          Read the docs <span aria-hidden="true">↗</span>
        </a>
        <a href="https://clawhub.ai" target="_blank" rel="noopener" class="action action-secondary">
          Browse ClawHub <span aria-hidden="true">↗</span>
        </a>
      </div>
    </header>

    <dl class="catalog-stats" aria-label="Current OpenClaw catalog snapshot">
      {catalogSnapshot.stats.map((stat) => (
        <div class="stat">
          <dt>{stat.label}</dt>
          <dd data-count-up={stat.value} aria-label={stat.value}>{stat.value}</dd>
        </div>
      ))}
    </dl>

    <section id="channels" class="catalog-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Message OpenClaw anywhere</p>
          <h2>Chat channels</h2>
          <p>
            Run several channels at once and route each conversation through the Gateway.
            Bundled channels ship with OpenClaw; official and external plugins install separately.
          </p>
        </div>
        <a href="https://docs.openclaw.ai/channels" target="_blank" rel="noopener">
          Channel directory ↗
        </a>
      </div>

      <div id="channel-catalog" class="catalog-grid channel-grid">
        {channels.map((item) => (
          <a
            href={item.docs}
            target="_blank"
            rel="noopener"
            class="catalog-card"
            style={`--accent: ${item.color}`}
          >
            <span class:list={['status-badge', `status-${item.status}`]}>{statusLabels[item.status]}</span>
            <span class="card-icon">
              {item.logo
                ? <img src={item.logo} alt="" class="brand-logo" width="30" height="30" loading="lazy" decoding="async" />
                : <Icon icon={item.icon} color={item.color} size={28} />}
            </span>
            <h3>{item.name}</h3>
            <p>{item.desc}</p>
          </a>
        ))}
      </div>
      <button
        type="button"
        class="channel-expander"
        aria-controls="channel-catalog"
        aria-expanded="false"
        data-channel-expander
        hidden
      >
        <span data-channel-expander-label>See all channels</span>
        <span class="channel-expander-icon" aria-hidden="true">
          <Icon icon="lucide:chevron-down" color="currentColor" size={16} />
        </span>
      </button>
    </section>

    <section id="models" class="catalog-section models-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Cloud, subscription, gateway, or local</p>
          <h2>Models and media providers</h2>
          <p>
            OpenClaw separates model choice, authentication, and execution runtime.
            Providers can also add search, speech, image, video, music, and media understanding.
          </p>
        </div>
        <a href="https://docs.openclaw.ai/providers" target="_blank" rel="noopener">
          Provider directory ↗
        </a>
      </div>

      <div class="catalog-grid provider-grid">
        {featuredProviders.map((item) => (
          <a
            href={item.docs}
            target="_blank"
            rel="noopener"
            class="catalog-card provider-card"
            style={`--accent: ${item.color}`}
          >
            <span class:list={['status-badge', `status-${item.status}`]}>{statusLabels[item.status]}</span>
            <span class="card-icon">
              {item.logo
                ? <img src={item.logo} alt="" class="brand-logo" width="30" height="30" loading="lazy" decoding="async" />
                : <Icon icon={item.icon} color={item.color} size={30} />}
            </span>
            <h3>{item.name}</h3>
            <p>{item.desc}</p>
          </a>
        ))}
      </div>

      <div class="group-grid">
        {providerGroups.map((group) => (
          <article class="link-group" style={`--accent: ${group.color}`}>
            <div class="link-group-heading">
              <Icon icon={group.icon} color={group.color} size={24} />
              <div>
                <h3>{group.name}</h3>
                <p>{group.desc}</p>
              </div>
            </div>
            <ul>
              {group.links.map((link) => (
                <li><a href={link.docs} target="_blank" rel="noopener">{link.name}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section id="tools" class="catalog-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Act, coordinate, and keep working</p>
          <h2>Built-in tools and automation</h2>
          <p>
            Tools are callable actions, skills teach repeatable workflows, and plugins add
            runtime capabilities such as providers, channels, hooks, and tools.
          </p>
        </div>
        <a href="https://docs.openclaw.ai/tools" target="_blank" rel="noopener">
          Tools overview ↗
        </a>
      </div>

      <div class="catalog-grid capability-grid">
        {capabilities.map((item) => (
          <a
            href={item.docs}
            target="_blank"
            rel="noopener"
            class="catalog-card capability-card"
            style={`--accent: ${item.color}`}
          >
            <span class="card-icon"><Icon icon={item.icon} color={item.color} size={28} /></span>
            <h3>{item.name}</h3>
            <p>{item.desc}</p>
          </a>
        ))}
      </div>

      <div class="automation-band">
        <div class="automation-intro">
          <span class="automation-mark"><Icon icon="lucide:workflow" color="var(--coral-bright)" size={26} /></span>
          <div>
            <p class="section-kicker">Background work</p>
            <h3>Automation is more than cron</h3>
            <p>Choose the right mechanism for schedules, monitoring, events, durable flows, and persistent instructions.</p>
          </div>
        </div>
        <ol class="automation-links">
          {automationLinks.map((link, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <a href={link.docs} target="_blank" rel="noopener">{link.name} ↗</a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section id="platforms" class="catalog-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Run here. Reach there.</p>
          <h2>Gateway hosts and companion nodes</h2>
          <p>
            The Gateway runs on desktop and server operating systems. Companion nodes connect
            mobile and native device capabilities without hosting the Gateway themselves.
          </p>
        </div>
        <a href="https://docs.openclaw.ai/platforms" target="_blank" rel="noopener">
          Platform guide ↗
        </a>
      </div>

      <div class="platform-columns">
        <div class="platform-column">
          <div class="platform-heading">
            <Icon icon="lucide:server-cog" color="var(--coral-bright)" size={24} />
            <div>
              <h3>Gateway hosts</h3>
              <p>Run the agent runtime, channels, automation, and services.</p>
            </div>
          </div>
          <div class="platform-list">
            {gatewayHosts.map((item) => (
              <a href={item.docs} target="_blank" rel="noopener" style={`--accent: ${item.color}`}>
                <span class="card-icon">
                  {item.logo
                    ? <img src={item.logo} alt="" class="brand-logo" width="25" height="25" loading="lazy" decoding="async" />
                    : <Icon icon={item.icon} color={item.color} size={25} />}
                </span>
                <span><strong>{item.name}</strong><small>{item.desc}</small></span>
              </a>
            ))}
          </div>
        </div>

        <div class="platform-column">
          <div class="platform-heading">
            <Icon icon="lucide:monitor-smartphone" color="var(--cyan-bright)" size={24} />
            <div>
              <h3>Companion nodes</h3>
              <p>Expose camera, screen, voice, location, Canvas, and native actions.</p>
            </div>
          </div>
          <div class="platform-list">
            {companionNodes.map((item) => (
              <a href={item.docs} target="_blank" rel="noopener" style={`--accent: ${item.color}`}>
                <span class="card-icon">
                  {item.logo
                    ? <img src={item.logo} alt="" class="brand-logo" width="25" height="25" loading="lazy" decoding="async" />
                    : <Icon icon={item.icon} color={item.color} size={25} />}
                </span>
                <span><strong>{item.name}</strong><small>{item.desc}</small></span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="community" class="catalog-section community-section">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Extend the runtime</p>
          <h2>Community skills and plugins</h2>
          <p>
            ClawHub is the public registry for reusable skills and installable plugins.
            Community extensions are labeled separately from capabilities included in OpenClaw.
          </p>
        </div>
        <a href="https://clawhub.ai" target="_blank" rel="noopener">Browse ClawHub ↗</a>
      </div>

      <div class="group-grid community-grid">
        {communityGroups.map((group) => (
          <article class="link-group community-group" style={`--accent: ${group.color}`}>
            <div class="link-group-heading">
              <Icon icon={group.icon} color={group.color} size={24} />
              <div>
                <h3>{group.name}</h3>
                <p>{group.desc}</p>
              </div>
            </div>
            <ul>
              {group.links.map((link) => (
                <li><a href={link.docs} target="_blank" rel="noopener">{link.name}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div class="community-cta">
        <div>
          <p class="section-kicker">Need something else?</p>
          <h3>Install it, or build it.</h3>
          <p>Plugins can add tools, channels, providers, hooks, speech, realtime voice, media generation, and packaged skills.</p>
        </div>
        <div class="community-actions">
          <a href="https://clawhub.ai" target="_blank" rel="noopener" class="action action-primary">Explore ClawHub ↗</a>
          <a href="https://docs.openclaw.ai/plugins/building-plugins" target="_blank" rel="noopener" class="action action-secondary">Build a plugin ↗</a>
        </div>
      </div>
    </section>

    <SiteFooter current="integrations" spacing="compact" />
  </main>
</Layout>

<script>
  const counters = document.querySelectorAll<HTMLElement>('[data-count-up]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const numberFormatter = new Intl.NumberFormat('en-US');

  const animateCounter = (counter: HTMLElement) => {
    const target = Number.parseInt(counter.dataset.countUp ?? '', 10);
    if (!Number.isFinite(target)) return;

    const duration = 900;
    const startedAt = performance.now();

    const updateCounter = (now: number) => {
      const progress = Math.min((now - startedAt) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      counter.textContent = numberFormatter.format(Math.round(target * easedProgress));

      if (progress < 1) requestAnimationFrame(updateCounter);
    };

    requestAnimationFrame(updateCounter);
  };

  if (!prefersReducedMotion) {
    const counterObserver = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const counter = entry.target as HTMLElement;
        counterObserver.unobserve(counter);
        animateCounter(counter);
      }
    }, { threshold: 0.6 });

    for (const counter of counters) {
      counter.textContent = '0';
      counterObserver.observe(counter);
    }
  }

  const channelGrid = document.querySelector<HTMLElement>('#channel-catalog');
  const channelExpander = document.querySelector<HTMLButtonElement>('[data-channel-expander]');
  const channelExpanderLabel = channelExpander?.querySelector<HTMLElement>('[data-channel-expander-label]');

  if (channelGrid && channelExpander && channelExpanderLabel) {
    channelGrid.classList.add('is-collapsed');
    channelExpander.hidden = false;

    channelExpander.addEventListener('click', () => {
      const isCollapsed = channelGrid.classList.toggle('is-collapsed');
      channelExpander.setAttribute('aria-expanded', String(!isCollapsed));
      channelExpanderLabel.textContent = isCollapsed ? 'See all channels' : 'Show fewer channels';
    });
  }
</script>

<style>
  .stars {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.56;
    background-image:
      radial-gradient(1px 1px at 20px 30px, rgba(255,255,255,0.82), transparent),
      radial-gradient(1px 1px at 74px 110px, rgba(255,255,255,0.48), transparent),
      radial-gradient(1px 1px at 130px 62px, rgba(0,229,204,0.64), transparent),
      radial-gradient(1px 1px at 196px 144px, rgba(255,77,77,0.54), transparent);
    background-size: 230px 180px;
  }

  .page-shell {
    position: relative;
    z-index: 1;
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 32px 0 48px;
  }

  .hero {
    max-width: 840px;
    margin: 0 auto;
    padding: 40px 0 44px;
    text-align: center;
    animation: fadeInUp 0.6s ease-out;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-heading > a {
    color: var(--coral-bright);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
  }

  .section-heading > a:hover {
    color: var(--cyan-bright);
  }

  .section-kicker {
    color: var(--cyan-bright);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 3.75rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--coral-bright) 50%, var(--cyan-bright) 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-lede {
    max-width: 760px;
    margin: 16px auto 0;
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .hero-copy {
    max-width: 700px;
    margin: 10px auto 0;
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .hero-actions,
  .community-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 24px;
  }

  .action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 16px;
    border: 1px solid var(--border-subtle);
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .action span {
    margin-left: 4px;
  }

  .action:hover {
    transform: translateY(-1px);
  }

  .action-primary {
    border-color: var(--coral-bright);
    background: var(--coral-bright);
    color: #050810;
  }

  .action-primary:hover {
    background: var(--cyan-bright);
    border-color: var(--cyan-bright);
  }

  .action-secondary {
    background: var(--surface-card-strong);
    color: var(--text-primary);
  }

  .action-secondary:hover {
    border-color: var(--cyan-bright);
    color: var(--cyan-bright);
  }

  .catalog-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 8px 0 26px;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  .stat {
    display: flex;
    flex-direction: column-reverse;
    gap: 3px;
    min-height: 92px;
    padding: 16px 20px;
    border-right: 1px solid var(--border-subtle);
  }

  .stat:last-child {
    border-right: 0;
  }

  .stat dt {
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .stat dd {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .catalog-section {
    margin-bottom: 76px;
    scroll-margin-top: 82px;
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 28px;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .section-heading h2 {
    margin: 4px 0 7px;
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1.12;
    letter-spacing: 0;
  }

  .section-heading p:not(.section-kicker) {
    max-width: 720px;
    color: var(--text-secondary);
    font-size: 0.92rem;
  }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .channel-grid.is-collapsed > .catalog-card:nth-child(n + 13) {
    display: none;
  }

  .channel-expander {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 38px;
    margin: 18px auto 0;
    padding: 0 12px;
    border: 1px solid var(--border-subtle);
    border-radius: 5px;
    background: var(--surface-card);
    color: var(--text-secondary);
    font: inherit;
    font-size: 0.76rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
  }

  .channel-expander[hidden] {
    display: none;
  }

  .channel-expander:hover,
  .channel-expander:focus-visible {
    border-color: var(--border-accent);
    background: var(--surface-card-strong);
    color: var(--text-primary);
  }

  .channel-expander:focus-visible {
    outline: none;
    border-color: var(--cyan-bright);
    box-shadow: 0 0 0 1px var(--cyan-bright);
  }

  .channel-expander-icon {
    display: inline-flex;
    line-height: 0;
    transition: transform 0.18s ease;
  }

  .channel-expander[aria-expanded='true'] .channel-expander-icon {
    transform: rotate(180deg);
  }

  .catalog-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 148px;
    padding: 18px;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: var(--surface-card);
    color: var(--text-primary);
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }

  .catalog-card:hover,
  .catalog-card:focus-visible {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 70%, var(--border-subtle));
    background: var(--surface-card-strong);
  }

  .card-icon {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    margin-bottom: 15px;
  }

  .brand-logo {
    display: block;
    width: 30px;
    height: 30px;
    object-fit: contain;
  }

  .catalog-card h3 {
    margin: 0 0 5px;
    padding-right: 12px;
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .catalog-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .status-badge {
    position: absolute;
    top: 12px;
    right: 10px;
    max-width: 96px;
    padding: 3px 6px;
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    background: var(--bg-surface);
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    text-transform: uppercase;
  }

  .link-group li {
    display: inline-flex;
  }

  .provider-card {
    min-height: 164px;
  }

  .group-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 12px;
  }

  .link-group {
    min-width: 0;
    padding: 20px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: var(--surface-card);
  }

  .link-group-heading {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }

  .link-group h3,
  .platform-heading h3,
  .automation-intro h3,
  .community-cta h3 {
    margin: 0 0 3px;
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .link-group p,
  .platform-heading p,
  .automation-intro p:not(.section-kicker),
  .community-cta p:not(.section-kicker) {
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .link-group ul {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .link-group a {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 8px;
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    color: var(--text-secondary);
    font-size: 0.7rem;
    font-weight: 700;
    text-decoration: none;
  }

  .link-group a:hover,
  .link-group a:focus-visible {
    border-color: var(--accent);
